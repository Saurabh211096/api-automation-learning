    {
      "name": "GET Pet by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "// Assert the name field\r",
              "pm.test(\"Pet name is Unique_QA_Dog\", () => {\r",
              "    pm.expect(jsonData.name).to.eql(\"Unique_QA_Dog\");\r",
              "});\r",
              "\r",
              "// Assert the status field\r",
              "pm.test(\"Pet status is available\", () => {\r",
              "    pm.expect(jsonData.status).to.eql(\"available\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
